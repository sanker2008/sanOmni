{
  "identifier": "default",
  "description": "Default capabilities for sanMediaBox",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:path:allow-resolve-directory",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$HOME/**" },
        { "path": "**" }
      ]
    }
  ]
}
