{
  "identifier": "default",
  "description": "Default capabilities for sanOmni",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:path:allow-resolve-directory",
    "core:webview:default",
    "core:webview:allow-set-webview-zoom",
    "core:webview:allow-webview-position",
    "core:webview:allow-webview-size",
    "core:webview:allow-internal-toggle-devtools",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-copy-file",
    "fs:allow-create",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$HOME/**" },
        { "path": "**" }
      ]
    },
    "shell:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "^https://github\\.com/sanker2008/sanOmni(/.*)?$"
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "explorer",
          "cmd": "explorer",
          "args": true,
          "sidecar": false
        },
        {
          "name": "open",
          "cmd": "open",
          "args": true,
          "sidecar": false
        },
        {
          "name": "xdg-open",
          "cmd": "xdg-open",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
