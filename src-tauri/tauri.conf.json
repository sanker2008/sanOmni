{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sanOmni",
  "version": "1.2.2",
  "identifier": "com.sanomni.app",
  "build": {
    "beforeDevCommand": "node ./scripts/ensure-vite-for-tauri.mjs",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "sanOmni",
        "width": 1400,
        "height": 900,
        "minWidth": 400,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost blob:; connect-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/sanker2008/sanOmni/releases/latest/download/latest.json",
        "https://ghfast.top/https://github.com/sanker2008/sanOmni/releases/latest/download/latest.json",
        "https://mirror.ghproxy.com/https://github.com/sanker2008/sanOmni/releases/latest/download/latest.json",
        "https://ghproxy.net/https://github.com/sanker2008/sanOmni/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDQTYwNzc5QTQ0Mjc2NjMKUldSamRrS2tlUWVtTEQ3VUx2MERIZ3FqZkZVdXQ2TlorSkZtN1FtTGpuR251eU01SndzOFVqSUsK"
    }
  }
}
