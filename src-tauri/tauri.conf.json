{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sanOmni",
  "version": "1.0.1",
  "identifier": "com.sanomni.app",
  "build": {
    "beforeDevCommand": "node ./scripts/ensure-vite-for-tauri.mjs",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "sanOmni",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sanker2008/sanOmni/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwRkJCMDEyNzRFQzgwNTgKUldSWWdPeDBFckQ3TUl3a2hUUU5IK0czQ3c4U2gyeXh0U3N6em5xTUF6ZUxMYXVWV29GVkZYSVAK"
    }
  }
}